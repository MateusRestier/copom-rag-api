# ─────────────────────────────────────────────
#  Provider Selection
#  Change values to swap providers — no code changes needed.
#  EMBEDDING_PROVIDER must match what copom-vector-pipeline used for ingestion.
# ─────────────────────────────────────────────
EMBEDDING_PROVIDER=gemini
LLM_PROVIDER=gemini

# ─────────────────────────────────────────────
#  Google Gemini
# ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
# Embedding model — MUST match what was used during ingestion (model + dimensions).
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSIONS=1536
# LLM model for answer generation.
GEMINI_LLM_MODEL=gemini-1.5-flash

# ─────────────────────────────────────────────
#  PostgreSQL + pgvector
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://copom:copom@localhost:5432/copom_rag

# ─────────────────────────────────────────────
#  RAG tuning
# ─────────────────────────────────────────────
RETRIEVAL_TOP_K=10
CONTEXT_TOP_K=5
RERANK_WITH_LLM=true
LLM_TEMPERATURE=0.3
MAX_OUTPUT_TOKENS=2048
MAX_CONTEXT_TOKENS=6000

# ─────────────────────────────────────────────
#  API security (optional)
#  Set to a secret string to enable X-API-Key header auth.
#  Leave empty to disable authentication (dev mode).
# ─────────────────────────────────────────────
COPOM_API_KEY=

# ─────────────────────────────────────────────
#  Prompt customization (optional)
#  Path to a YAML file with custom prompt templates.
#  Leave empty to use the built-in Python default templates.
# ─────────────────────────────────────────────
COPOM_PROMPTS_FILE=
